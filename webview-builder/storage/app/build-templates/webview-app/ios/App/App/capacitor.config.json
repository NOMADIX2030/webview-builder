{
	"appId": "com.webview.app",
	"appName": "WebviewApp",
	"webDir": "www",
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": false,
			"launchShowDuration": 0,
			"launchFadeOutDuration": 300,
			"backgroundColor": "#ffffff"
		}
	},
	"server": {
		"url": "{{WEB_URL}}",
		"cleartext": true,
		"allowNavigation": [
			"kauth.kakao.com",
			"kapi.kakao.com",
			"accounts.kakao.com",
			"accounts.google.com",
			"www.google.com",
			"nid.naver.com",
			"naver.com",
			"www.facebook.com",
			"facebook.com",
			"appleid.apple.com",
			"apple.com",
			"{{APP_HOST}}"
		]
	},
	"packageClassList": []
}
