# ===========================================
# 웹뷰 앱 빌더 — .gitignore (Laravel Blade + Tailwind)
# 맥북 클론 후 .env만 생성하면 바로 실행 가능하도록
# ===========================================

# ----- 환경 (반드시 제외, 클론 후 .env 생성)
.env
.env.local
.env.*.local
!.env.example

# ----- 의존성 (composer install, npm install로 복구)
node_modules/
vendor/

# ----- 빌드 산출물
webview-builder/storage/app/builds/*
!webview-builder/storage/app/builds/.gitkeep

# ----- 업로드 파일 (런타임, 사용자 데이터)
webview-builder/storage/app/public/uploads/*
!webview-builder/storage/app/public/uploads/.gitkeep
webview-builder/storage/app/private/uploads/*
!webview-builder/storage/app/private/uploads/.gitkeep

# ----- Laravel
webview-builder/storage/logs/*
!webview-builder/storage/logs/.gitkeep
webview-builder/storage/framework/cache/data/*
!webview-builder/storage/framework/cache/data/.gitkeep
webview-builder/storage/framework/sessions/*
!webview-builder/storage/framework/sessions/.gitkeep
webview-builder/storage/framework/views/*
!webview-builder/storage/framework/views/.gitkeep
webview-builder/bootstrap/cache/*.php
!webview-builder/bootstrap/cache/.gitignore

# ----- IDE / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# ----- 보안 (비밀번호 등 절대 커밋 금지)
.cursor/rules/sudo-password.mdc

# ----- 임시
.tmp-cap-template/
tmp/
