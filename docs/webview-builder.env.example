# 웹뷰 앱 빌드 서비스 — Laravel 환경 변수 템플릿
# cp docs/webview-builder.env.example webview-builder/.env 후 DB_PASSWORD 등 수정

APP_NAME="Webview Builder"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# 데이터베이스 (webview_builder)
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=webview_builder
DB_USERNAME=awekers
DB_PASSWORD=

# Redis (선택 - Queue/Cache)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel 기본
BROADCAST_DRIVER=log
CACHE_STORE=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# 빌드 경로 (APK 빌드 시 docs/BUILD_ENVIRONMENT.md 참조)
BUILD_TEMPLATE_PATH=storage/app/build-templates/webview-app
BUILD_OUTPUT_PATH=storage/app/builds
